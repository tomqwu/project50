DATABASE_URL="postgresql://project50:project50@localhost:5432/project50?schema=public"
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="project50-media"
AUTH_SECRET="dev-secret-change-me"
AUTH_E2E="1"
RECAP_FAKE="1"
# Real OAuth login (optional in dev — the gated "demo account" button works without these).
# Google: Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web app).
#   Authorized JS origin:   http://localhost:3000
#   Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Facebook: developers.facebook.com → your app → Facebook Login → Settings.
#   Valid OAuth Redirect URI: http://localhost:3000/api/auth/callback/facebook
#   FACEBOOK_CLIENT_ID = App ID, FACEBOOK_CLIENT_SECRET = App Secret (Settings → Basic)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# Social publishing (optional — omit to use deep-link/webshare fallbacks)
FB_PAGE_ID=
FB_PAGE_TOKEN=
IG_USER_ID=
IG_TOKEN=
WECHAT_APP_ID=
