DATABASE_URL="postgresql://project50:project50@localhost:5432/project50?schema=public"
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="project50-media"
AUTH_SECRET="dev-secret-change-me"
AUTH_E2E="1"
RECAP_FAKE="1"
# Real OAuth login (optional in dev — the gated "demo account" button works without these).
# Google: Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web app).
#   Authorized JS origin:   http://localhost:3000
#   Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Facebook: developers.facebook.com → your app → Facebook Login → Settings.
#   Valid OAuth Redirect URI: http://localhost:3000/api/auth/callback/facebook
#   FACEBOOK_CLIENT_ID = App ID, FACEBOOK_CLIENT_SECRET = App Secret (Settings → Basic)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# Mobile (Expo) — public, inlined into the app bundle (NEVER put secrets here).
#   Used by apps/mobile; copy into apps/mobile/.env and restart `expo start -c`.
#   The mobile FB OAuth code is exchanged server-side at POST /api/mobile/auth/facebook.
EXPO_PUBLIC_FACEBOOK_APP_ID=
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
# Social publishing (optional — omit to use deep-link/webshare fallbacks)
FB_PAGE_ID=
FB_PAGE_TOKEN=
IG_USER_ID=
IG_TOKEN=
WECHAT_APP_ID=
# Error tracking (Sentry) — OPT-IN. Leave BLANK to disable: with no DSN the web
# app skips Sentry init entirely (no SDK, no network) and the build/e2e are
# unaffected. To enable, create a project at sentry.io and paste its DSN below.
#   SENTRY_DSN              = server + edge runtime (NOT exposed to the browser)
#   NEXT_PUBLIC_SENTRY_DSN  = browser/client runtime (inlined into the JS bundle)
# Both are usually the same DSN. Source-map upload (optional) additionally needs
# SENTRY_ORG, SENTRY_PROJECT and SENTRY_AUTH_TOKEN — set those only in CI/prod.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Sentry source-map upload — CI/prod build only (omit in dev). SENTRY_AUTH_TOKEN
# is sensitive: build-time only, never shipped to runtime/browser.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Monetization (Stripe subscriptions) — OPT-IN. Leave BLANK to disable: with no
# STRIPE_SECRET_KEY the billing endpoints return 503 "billing_not_configured"
# (no Stripe client is constructed) and the app builds/runs/e2e unaffected. The
# entitlement endpoint still works (everyone is "free" without a subscription).
# To enable, create a Stripe account → Developers → API keys, and a recurring
# Price for the premium plan.
#   STRIPE_SECRET_KEY     = server-side secret key (sk_test_… / sk_live_…). SENSITIVE.
#   STRIPE_WEBHOOK_SECRET = signing secret for the billing webhook endpoint
#                           (Developers → Webhooks → your endpoint → Signing secret,
#                           whsec_…). Required to verify POST /api/billing/webhook.
#   STRIPE_PRICE_ID       = default recurring Price id (price_…) used by checkout
#                           when the request omits one.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Deployment / auth URLs (staging + prod; dev defaults to http://localhost:3000).
# AUTH_URL must be the real https://… origin in prod — its scheme gates Secure
# session cookies (see apps/web/lib/auth-config.ts, docs/SECRETS.md).
APP_BASE_URL=
AUTH_URL=
# Trust the host header behind a proxy / non-canonical host (set "1" if needed).
AUTH_TRUST_HOST=
# Public base URL for serving stored media; falls back to S3_ENDPOINT.
S3_PUBLIC_URL=

# Test-only login flags — NEVER set in production (docs/SECRETS.md).
# AUTH_E2E is the primary gate (set above for dev). AUTH_E2E_ALLOW_PROD is a
# CI-e2e-only override; leave unset everywhere else.
AUTH_E2E_ALLOW_PROD=

# See docs/SECRETS.md for purpose, storage, and rotation of every secret above.

# Email reminders + digests (#121) — OPT-IN. Leave BLANK to disable: with no
# RESEND_API_KEY/EMAIL_FROM the reminder service is a logged no-op (no SDK, no
# network) and build/tests are unaffected (see apps/web/lib/email.ts).
#   RESEND_API_KEY = Resend API key (resend.com → API Keys). Sent as a Bearer
#                    token to https://api.resend.com/emails via fetch (no SDK dep).
#   EMAIL_FROM     = verified sender, e.g. "Project 50 <noreply@yourdomain.com>".
# NOTE: User has no email field yet — reminders currently resolve a PLACEHOLDER
# address from the handle. Add User.email (+ opt-out preference) before enabling
# real sends. See apps/web/lib/api/reminders.ts.
RESEND_API_KEY=
EMAIL_FROM=
# Shared secret protecting the POST /api/cron/reminders trigger so only a
# scheduler can fire it. Unset → endpoint disabled (503). Set → callers must send
# `Authorization: Bearer ${CRON_SECRET}`. Scheduling examples in the route file.
CRON_SECRET=

# Product analytics — OPT-IN and provider-agnostic. Leave BLANK to disable:
# with no key the analytics layer is a complete no-op (no queue, no network)
# and the build/tests are unaffected (see apps/web/lib/analytics.ts). Events are
# additionally gated on the user's cookie/tracking consent, so even when a key
# is set nothing is recorded until the user accepts. To enable, set the public
# key below; events are pushed onto window.p50Analytics and POSTed to
# /api/analytics — point that at (or drain the queue into) your provider
# (PostHog, Segment, Amplitude, a self-hosted sink, …).
#   NEXT_PUBLIC_ANALYTICS_KEY = public analytics/project key. Inlined into the
#                               client bundle by Next — NOT a secret.
NEXT_PUBLIC_ANALYTICS_KEY=
