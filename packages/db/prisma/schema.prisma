generator client {
  provider = "prisma-client-js"
  // native  -> local dev (macOS / whatever the host is).
  // debian-openssl-3.0.x      -> linux/amd64 Debian (node:20-bookworm-slim on Azure Container Apps).
  // linux-arm64-openssl-3.0.x -> linux/arm64 Debian (Apple Silicon / arm64 build host).
  // Both Debian targets are bundled so the query engine loads in the container
  // regardless of the build/runtime CPU architecture.
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Provider {
  GOOGLE
  FACEBOOK
}

enum GoalType {
  TARGET
  BINARY
}

enum Visibility {
  PUBLIC
  FOLLOWERS
  PRIVATE
}

enum ReactionKind {
  CHEER
  COMMENT
}

enum MilestoneKind {
  COMPLETED_7
  COMPLETED_25
  COMPLETED_50
  STREAK_7
  STREAK_30
}

enum RecapKind {
  DAY
  WEEK
  FIFTY
}

enum ChallengeKind {
  STANDARD
  PROJECT50
}

enum ChallengeStatus {
  ACTIVE
  FAILED
  COMPLETED
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  NONE
}

model User {
  id               String        @id @default(cuid())
  handle           String        @unique
  // Optional email, set when a user signs in via the email magic-link flow
  // (#50). Unique so a given address maps to exactly one account; nullable so
  // existing OAuth/e2e users (which never had an email column) stay valid.
  email            String?       @unique
  displayName      String
  avatarUrl        String?
  isAdmin          Boolean       @default(false)
  createdAt        DateTime      @default(now())
  identities       Identity[]
  challenges       Challenge[]
  activities       Activity[]
  reactions        Reaction[]
  following        Follow[]      @relation("follower")
  followers        Follow[]      @relation("followee")
  blocksMade       Block[]       @relation("BlocksMade")
  blocksReceived   Block[]       @relation("BlocksReceived")
  reports          Report[]
  subscription     Subscription?
  // Stable, per-user share code for the referral program (#127). Lazily
  // populated by getOrCreateReferralCode; nullable so existing rows are valid.
  referralCode     String?       @unique
  // Referrals this user initiated (people they brought in).
  referralsMade    Referral[]    @relation("ReferrerReferrals")
  // The single referral that brought this user in, if any.
  referredBy       Referral?     @relation("ReferredUser")
  // Notification preferences (#122). Whether the user receives email reminders,
  // and an optional quiet-hours window (local hours 0-23) during which the
  // reminder sender stays silent. Nullable hours = no quiet window; when both
  // are set the window may wrap past midnight (e.g. 22 → 7).
  remindersEnabled Boolean       @default(true)
  quietHoursStart  Int?
  quietHoursEnd    Int?
}

/// Single-use email magic-link sign-in tokens (#50). A request stores the SHA-256
/// hash of a random token (never the raw token) with a short TTL; verification
/// looks the hash up, checks it is unexpired and unused, and stamps `usedAt` so
/// it cannot be replayed. Rows are env-gated: created only when email is
/// configured, and safe to leave for OAuth/e2e-only deployments (the table is
/// simply never written).
model MagicLinkToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  // Housekeeping: prune expired/old tokens and look up a user's pending links.
  @@index([email])
  @@index([expiresAt])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  blocker   User     @relation("BlocksMade", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  // Reverse lookup ("who blocked this user") and cascade deletes on the blocked user.
  @@index([blockedId])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  targetType String
  targetId   String
  reason     String
  createdAt  DateTime @default(now())

  // Moderation review groups reports by what was reported.
  @@index([targetType, targetId])
}

model Identity {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          Provider
  providerAccountId String
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  // FK lookup support for the User -> identities relation and cascade deletes.
  @@index([userId])
}

model Follow {
  followerId String
  followeeId String
  follower   User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followee   User     @relation("followee", fields: [followeeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@id([followerId, followeeId])
  // The composite PK leads with followerId; add a followeeId index for reverse
  // lookups ("who follows this user") and cascade deletes on the followee.
  @@index([followeeId])
}

model Challenge {
  id          String          @id @default(cuid())
  ownerId     String
  owner       User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  goalType    GoalType
  unit        String?
  dailyTarget Float?
  startDate   String
  timezone    String          @default("UTC")
  lengthDays  Int             @default(50)
  kind        ChallengeKind   @default(STANDARD)
  status      ChallengeStatus @default(ACTIVE)
  visibility  Visibility      @default(PUBLIC)
  shareId     String          @unique @default(cuid())
  createdAt   DateTime        @default(now())
  activities  Activity[]
  dayStatuses DayStatus[]
  milestones  Milestone[]
  recaps      Recap[]
  ruleChecks  RuleCheck[]

  // Owner's challenge list (listChallenges) and cascade deletes on the owner.
  @@index([ownerId])
  // Active / latest Project 50 run lookup: where ownerId+kind+status.
  @@index([ownerId, kind, status])
}

model Activity {
  id           String          @id @default(cuid())
  challengeId  String
  challenge    Challenge       @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayKey       String
  activityType String?
  amount       Float?
  done         Boolean         @default(false)
  note         String?
  mood         Int?
  createdAt    DateTime        @default(now())
  media        ActivityMedia[]
  reactions    Reaction[]

  @@index([challengeId, dayKey])
  // FK lookup support for the User -> activities relation and cascade deletes.
  @@index([userId])
}

model ActivityMedia {
  id         String   @id @default(cuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  objectKey  String
  width      Int
  height     Int
  order      Int      @default(0)
}

model DayStatus {
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  dayKey      String
  totalAmount Float     @default(0)
  completed   Boolean   @default(false)

  @@id([challengeId, dayKey])
}

model Reaction {
  id         String       @id @default(cuid())
  activityId String
  activity   Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind       ReactionKind
  text       String?
  createdAt  DateTime     @default(now())

  // Cheer/comment counts are queried per activity; also covers cascade deletes.
  @@index([activityId])
}

model Milestone {
  id          String        @id @default(cuid())
  challengeId String
  challenge   Challenge     @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  kind        MilestoneKind
  earnedAt    DateTime      @default(now())

  @@unique([challengeId, kind])
}

model Recap {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  kind        RecapKind
  objectKey   String
  createdAt   DateTime  @default(now())

  // listRecaps filters by challengeId; also covers cascade deletes.
  @@index([challengeId])
}

model RuleCheck {
  id          String    @id @default(cuid())
  challengeId String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  dayKey      String
  ruleId      Int
  done        Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@unique([challengeId, dayKey, ruleId])
  @@index([challengeId, dayKey])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(NONE)
  plan                 String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

/// Referral program (#127): records that `referredUser` signed up via
/// `referrer`'s code. `referredUserId` is unique so a user can be referred at
/// most once; `code` captures the referrer's code at claim time. Cascades on
/// either user's deletion.
model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  referrer       User     @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId String   @unique
  referredUser   User     @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  code           String
  createdAt      DateTime @default(now())

  // Counting / listing a referrer's referrals, plus cascade on the referrer.
  @@index([referrerId])
}
