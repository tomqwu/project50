# Object storage backend selection (apps/web/lib/storage.ts)
#
# The web app uses ONE object-storage backend, chosen at runtime by env. There
# are THREE Azure modes plus the S3/MinIO default:
#
#   - S3 / MinIO (default): used in local dev and on AWS. Configured via the
#     S3_* vars in the repo-root .env / .env.example. Active when no Azure
#     account is configured.
#
#   - Azure Blob, MANAGED IDENTITY (recommended for PROD): set
#     AZURE_STORAGE_ACCOUNT + AZURE_STORAGE_CONTAINER + AZURE_CLIENT_ID and OMIT
#     AZURE_STORAGE_KEY. The app authenticates as its managed identity
#     (DefaultAzureCredential) and signs short-lived *user-delegation* SAS URLs —
#     no long-lived account key in the environment. The user-delegation key is
#     fetched from the service and cached (~1h). The identity needs the
#     "Storage Blob Data Contributor" role on the account/container.
#
#   - Azure Blob, SHARED KEY (local/dev convenience): additionally set
#     AZURE_STORAGE_KEY. SAS URLs are then signed with the account key instead.
#
# In every Azure mode, presigned PUT/GET are Blob SAS URLs (5-minute expiry) and
# the container is auto-created on first server-side upload.
# Leave all AZURE_* vars unset to keep the default S3/MinIO path.

# Azure storage account name (the "<account>" in <account>.blob.core.windows.net).
AZURE_STORAGE_ACCOUNT=

# Blob container that holds media/recap objects (created if missing).
AZURE_STORAGE_CONTAINER=

# Managed-identity mode only: client ID of the user-assigned managed identity to
# authenticate as. Leave blank to use the system-assigned identity. Has no effect
# when AZURE_STORAGE_KEY is set (shared-key mode).
AZURE_CLIENT_ID=

# Shared-key (account key) used to sign Blob SAS URLs.
# SET THIS to opt into shared-key mode (local/dev). LEAVE BLANK for managed
# identity (PROD) so the app uses user-delegation SAS and no account key exists
# in the environment.
# PROD: never hardcode a real key — prefer managed identity above. If you must
# use shared key, load it from Azure Key Vault and inject as a secret reference.
AZURE_STORAGE_KEY=
