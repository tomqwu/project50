# Object storage backend selection (apps/web/lib/storage.ts)
#
# The web app uses ONE object-storage backend, chosen at runtime by env:
#
#   - S3 / MinIO (default): used in local dev and on AWS. Configured via the
#     S3_* vars in the repo-root .env / .env.example.
#
#   - Azure Blob Storage: used when running on Azure (e.g. Container Apps)
#     without S3. Selected automatically when ALL THREE vars below are set.
#     Presigned PUT/GET become Blob SAS URLs (5-minute expiry); the container
#     is auto-created on first server-side upload.
#
# Leave the AZURE_* vars unset to keep the default S3/MinIO path.

# Azure storage account name (the "<account>" in <account>.blob.core.windows.net).
AZURE_STORAGE_ACCOUNT=

# Blob container that holds media/recap objects (created if missing).
AZURE_STORAGE_CONTAINER=

# Shared-key (account key) used to sign Blob SAS URLs.
# PROD: never hardcode this — load it from Azure Key Vault and inject as an env
# var / secret reference. Keep real keys out of source control; .env is gitignored.
AZURE_STORAGE_KEY=
