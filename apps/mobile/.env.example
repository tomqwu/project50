# Expo public env — inlined into the bundle at build time. NEVER put the App Secret here.
# After changing these, fully restart the bundler: `expo start -c`.
EXPO_PUBLIC_FACEBOOK_APP_ID=
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
# EAS projectId for Expo push tokens (getExpoPushTokenAsync). Required for real
# device push tokens in standalone/dev builds; unset is fine in Expo Go.
EXPO_PUBLIC_EAS_PROJECT_ID=
# Sentry DSN for crash/error reporting (@sentry/react-native). When set, the app
# initializes Sentry at startup; leave UNSET to fully disable reporting (no init)
# in dev/CI/Expo Go. Get the DSN from your Sentry project settings.
EXPO_PUBLIC_SENTRY_DSN=
