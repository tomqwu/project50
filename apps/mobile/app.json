{
  "expo": {
    "name": "Project 50",
    "slug": "project50",
    "scheme": "project50",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#121013"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.project50",
      "associatedDomains": [
        "applinks:project50.app"
      ]
    },
    "android": {
      "package": "com.anonymous.project50",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#121013"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "project50.app",
              "pathPrefix": "/oauth/callback"
            },
            {
              "scheme": "https",
              "host": "project50.app",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "project50"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#D6FF3F"
        }
      ]
    ]
  }
}
