# .env.staging.example — staging environment template (issue #22 / #18).
#
# Copy to `.env.staging` and fill in real values. `.env.staging` is git-ignored
# (it holds secrets — see docs/SECRETS.md). This template contains placeholders
# only. Used by docker-compose.staging.yml:
#   cp .env.staging.example .env.staging
#   docker compose --env-file .env.staging -f docker-compose.staging.yml up --build
#
# Cross-reference: docs/INFRA-STAGING.md (how to stand this up + the cloud path),
# docs/SECRETS.md (purpose/storage/rotation of every variable), docs/DEPLOY.md.

# ---------------------------------------------------------------------------
# Postgres backend (the postgres + pgbouncer services read these)
# ---------------------------------------------------------------------------
POSTGRES_USER=project50
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=project50

# ---------------------------------------------------------------------------
# Prisma connection pooling (#18)
# ---------------------------------------------------------------------------
# DATABASE_URL points at PgBouncer (port 6432, transaction mode). The
# `pgbouncer=true` flag tells Prisma to disable prepared statements, which are
# unsupported in transaction pooling. `connection_limit` caps the per-instance
# Prisma client pool; keep it small — PgBouncer does the real multiplexing.
# (Host is `pgbouncer` inside the compose network; use the pooler host/port in
# the cloud, e.g. Supabase :6543 or Neon's -pooler endpoint.)
DATABASE_URL="postgresql://project50:CHANGE_ME_strong_password@pgbouncer:6432/project50?pgbouncer=true&connection_limit=10"

# DIRECT_URL bypasses the pooler and connects straight to Postgres (port 5432).
# Prisma MIGRATIONS (`prisma migrate deploy`) need a direct, session-mode
# connection — they cannot run through a transaction-mode pooler.
#
# IMPORTANT: for Prisma to actually USE this, the datasource block in
# packages/db/prisma/schema.prisma must declare `directUrl = env("DIRECT_URL")`.
# That schema edit is OUT OF SCOPE for this infra change and is documented as a
# TODO in docs/INFRA-STAGING.md §"Prisma + PgBouncer". Until it is added, point
# DATABASE_URL at the DIRECT (5432) connection when running migrations, or run
# migrate deploy against DIRECT_URL via `prisma migrate deploy --schema ...`
# with DATABASE_URL temporarily set to this value.
DIRECT_URL="postgresql://project50:CHANGE_ME_strong_password@postgres:5432/project50"

# ---------------------------------------------------------------------------
# Auth (next-auth) — see docs/SECRETS.md
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_base64_32_bytes
# Public https origin in real staging; localhost for the local stack.
AUTH_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
# Behind the pooler/proxy the host header is non-canonical; trust it.
AUTH_TRUST_HOST=1

# ---------------------------------------------------------------------------
# Object storage (S3 / MinIO)
# ---------------------------------------------------------------------------
# In the local stack these are the MinIO root creds. In the cloud, use the
# managed bucket's endpoint + an access-key pair scoped to that bucket.
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE_ME_minio_secret
S3_BUCKET=project50-media

# ---------------------------------------------------------------------------
# OAuth (optional in staging — the demo-account login works without these).
# Set real staging OAuth apps with staging redirect URIs. See docs/SECRETS.md.
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Error tracking (Sentry) — opt-in; leave blank to disable. See docs/SECRETS.md.
# ---------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Test-only login flags — NEVER set in a real/shared staging that faces users.
AUTH_E2E=
AUTH_E2E_ALLOW_PROD=
